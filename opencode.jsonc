{
  "$schema": "https://opencode.ai/config.json",
  "code_ownership": [
    {
      "paths": [".harness/agents/*.md"],
      "mode": "read",
      "description": "Agent definitions — read-only to prevent accidental edits"
    },
    {
      "paths": [".harness/rules/*.md"],
      "mode": "read",
      "description": "Process rules — read-only, modify via PR review"
    },
    {
      "paths": [".harness/scripts/*.sh", ".harness/scripts/*.py"],
      "mode": "write",
      "description": "Harness automation scripts"
    },
    {
      "paths": [".opencode/*.json"],
      "mode": "write",
      "description": "OpenCode configuration"
    }
  ],
  "lsp": {
    "config": ".opencode/lsp.json"
  },
  "references": [
    "AGENTS.md",
    ".harness/README.md",
    ".harness/platform.md",
    ".harness/agents/owner-agent.md",
    ".harness/rules/quality-gates.md"
  ],
  "plugin": [],
  "provider": null
}
